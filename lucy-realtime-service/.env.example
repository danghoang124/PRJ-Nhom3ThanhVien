# =====================================================
#   LUCY Real-time Service – Environment Variables
# =====================================================

# Server
PORT=3000
NODE_ENV=development

# Agora SDK
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# Java Content Service
JAVA_API_URL=http://localhost:8085

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080

# Token expiry (seconds)
TOKEN_EXPIRY_SECONDS=3600

# JWT Auth
JWT_SECRET=LUCY_SuperSecretKey_2024_MustBe32CharsLong!

# Auth Service (.NET)
AUTH_SERVICE_URL=http://localhost:5000
