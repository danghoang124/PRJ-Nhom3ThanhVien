# =====================================================
#   LUCY Auth Service – Environment Variables
# =====================================================

# Server
ASPNETCORE_URLS=http://localhost:5000
ASPNETCORE_ENVIRONMENT=Development

# MySQL
MYSQL__SERVERHOST=localhost
MYSQL__SERVERPORT=3306
MYSQL__DATABASE=lucy_db
MYSQL__USER=root
MYSQL__PASSWORD=your_mysql_password_here

# JWT
JWT__KEY=LUCY_SuperSecretKey_2024_MustBe32CharsLong!
JWT__ISSUER=LUCYAuthService
JWT__AUDIENCE=LUCYMobileApp
JWT__EXPIRESINMINUTES=60
